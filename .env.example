# Scout — environment variables
# Copy this file to .env and fill in your values

# ------------------------------------------------------------------
# AI Chat (optional — file tree and scanning work without this)
# ------------------------------------------------------------------

# Your OpenAI API key — enables the Ask tab in Scout
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the model (default: gpt-4o-mini)
# SCOUT_AI_MODEL=gpt-4o

# Optional: use a different OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------

# Port for the Scout backend server (default: 3001)
# PORT=3001
